{
  "manifest_version": 3,
  "name": "QMem",
  "version": "1.0.0",
  "description": "AI 记忆迁移与本地长期记忆管理工具",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "clipboardRead",
    "idle",
    "alarms"
  ],

  "host_permissions": [
    "<all_urls>",
    "https://api.deepseek.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/clipboard_interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
