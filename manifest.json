{
  "manifest_version": 3,
  "name": "Demo Extension",
  "version": "1.0.0",
  "description": "Chrome 插件 - 抓取网页数据并提供弹出界面",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "clipboardRead"
  ],

  "host_permissions": [
    "<all_urls>",
    "https://api.deepseek.com/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background/background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/clipboard_interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
